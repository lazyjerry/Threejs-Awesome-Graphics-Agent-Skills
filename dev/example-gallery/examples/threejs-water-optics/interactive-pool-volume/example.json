{
  "title": "Interactive Pool Volume",
  "description": "A bounded water volume with a ping-pong heightfield storing height, velocity, and packed normals; draggable sphere displacement; finite-difference wave propagation; refractive water surface shading; and caustic light projection.",
  "backend": "WebGL2 / GLSL heightfield water",
  "techniques": [
    "RGBA ping-pong water state",
    "discrete wave equation propagation",
    "draggable sphere displacement into the water heightfield",
